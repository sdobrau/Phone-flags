{
    "manifest_version": 3,
    "name": "Phone Flags",
    "version": "1.0.0",
    "description": "Display flag near phone number based on code",
    "action": {
        "default_title": "Phone Flags"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "permissions": [
    ],
    "host_permissions": [
        "https://*/*",
        "http://*/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://*/*",
                "http://*/*"
            ],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["flags/*.png"],
            "matches": ["<all_urls>"]
        }
    ]
}
